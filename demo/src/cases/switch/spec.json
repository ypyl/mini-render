{
  "root": "card",
  "elements": {
    "card": {
      "type": "CaseContainer",
      "props": { "title": "Switch Demo", "description": "Conditional rendering using useValue — renders different subtrees based on store state.", "technicalDescription": "Spec\nCaseContainer → [ButtonGroup → [ActionButton×3], BoundField(bind: \"/appStatus\"), Switch(path: \"/appStatus\") → loading|loaded|error subtrees]\nState\n{} initially; at runtime: appStatus (\"loading\" | \"loaded\" | \"error\")\nFeatures\n• Switch — conditional rendering via useValue on store path\n• Action dispatch — setStatus handler with params\n• ButtonGroup — horizontal button layout\n• Multiple subtrees — different children per state branch" },
      "children": ["buttons", "statusLabel", "switch"]
    },
    "buttons": {
      "type": "ButtonGroup",
      "children": ["btnLoading", "btnLoaded", "btnError"]
    },
    "btnLoading": {
      "type": "ActionButton",
      "props": { "label": "Loading" },
      "on": { "click": { "action": "setStatus", "params": { "status": "loading" } } }
    },
    "btnLoaded": {
      "type": "ActionButton",
      "props": { "label": "Loaded" },
      "on": { "click": { "action": "setStatus", "params": { "status": "loaded" } } }
    },
    "btnError": {
      "type": "ActionButton",
      "props": { "label": "Error" },
      "on": { "click": { "action": "setStatus", "params": { "status": "error" } } }
    },
    "statusLabel": {
      "type": "BoundField",
      "props": { "bind": "/appStatus", "label": "Current Status" }
    },
    "switch": {
      "type": "Switch",
      "props": { "path": "/appStatus" },
      "children": ["loading", "loaded", "error"]
    },
    "loading": {
      "type": "StaticText",
      "props": { "text": "⏳ Loading..." }
    },
    "loaded": {
      "type": "Card",
      "props": { "title": "✅ Loaded" },
      "children": ["loadedText"]
    },
    "loadedText": {
      "type": "StaticText",
      "props": { "text": "Data loaded successfully!" }
    },
    "error": {
      "type": "Card",
      "props": { "title": "❌ Error" },
      "children": ["errorText"]
    },
    "errorText": {
      "type": "StaticText",
      "props": { "text": "Something went wrong." }
    }
  }
}
