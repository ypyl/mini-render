{
  "root": "card",
  "elements": {
    "card": {
      "type": "CaseContainer",
      "props": { "title": "Action Dispatch", "description": "Action dispatch with state feedback — button click saves a timestamp to the store." },
      "children": ["body"]
    },
    "body": {
      "type": "StackRow",
      "props": { "gap": "md", "align": "flex-start" },
      "children": ["toggleBtn", "btn", "status"]
    },
    "toggleBtn": {
      "type": "EditToggle",
      "on": {
        "edit": { "action": "startEdit" },
        "save": { "action": "saveEdit" },
        "cancel": { "action": "cancelEdit" }
      }
    },
    "btn": {
      "type": "ActionButton",
      "props": { "label": "Save Document" },
      "on": { "click": { "action": "saveDoc" } }
    },
    "status": {
      "type": "BoundField",
      "props": { "bind": "/savedAt", "label": "Last saved at" }
    }
  }
}
